# Copy to `.env` and fill in only the platforms you want. Leave the rest blank.
# The server auto-detects which platforms are configured. NEVER commit your .env.

# --- X / Twitter -----------------------------------------------------------
# developer.twitter.com -> Project & App -> Keys and tokens. App needs Read+Write.
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# --- Bluesky (easiest) -----------------------------------------------------
# Settings -> App Passwords on bsky.app. Use the app password, NOT your login.
BLUESKY_HANDLE=yourname.bsky.social
BLUESKY_APP_PASSWORD=

# --- Mastodon --------------------------------------------------------------
# Your instance -> Preferences -> Development -> New application.
# Scopes: write:statuses write:media
MASTODON_INSTANCE=https://mastodon.social
MASTODON_ACCESS_TOKEN=

# --- LinkedIn --------------------------------------------------------------
# OAuth2 token with scopes: openid w_member_social
LINKEDIN_ACCESS_TOKEN=

# --- Threads ---------------------------------------------------------------
# Meta developer dashboard -> Threads API. Long-lived token + your Threads user id.
THREADS_USER_ID=
THREADS_ACCESS_TOKEN=

# --- TikTok (stub, not yet active) -----------------------------------------
# Video-only, requires approved app. Placeholder for future wiring.
TIKTOK_ACCESS_TOKEN=
